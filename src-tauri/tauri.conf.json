{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Juice",
  "version": "0.1.0",
  "identifier": "com.cyborgoat.juice",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build && npm run package:runtime"
  },
  "app": {
    "windows": [
      {
        "title": "Juice",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/**/*",
      "../scripts/build-cubicles-server.mjs",
      "../scripts/run-cubicles-server.mjs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
