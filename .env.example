# Juice environment configuration
# Copy this file to .env and fill in the values for your machine.

# Path to the cubicles-ts repository root (development mode).
# Used by scripts to locate and build the Cubicles server.
JUICE_CUBICLES_ROOT=/path/to/cubicles-ts

# Path to the bundled Cubicles runtime (production/packaged mode).
# Leave empty or unset during development.
# JUICE_BUNDLED_CUBICLES_ROOT=

# Cubicles server host and port
HOST=127.0.0.1
PORT=7788
