# Juice environment configuration
# Copy this file to .env and fill in the values for your machine.
# Variables prefixed with VITE_ are baked into the frontend bundle by Vite.
# Other variables are only available in Node.js scripts (not the browser bundle).

# ── Scripts (Node.js only) ───────────────────────────────────────────────────

# Path to the cubicles-ts repository root (development mode).
JUICE_CUBICLES_ROOT=/path/to/cubicles-ts

# Cubicles server host/port when starting via scripts directly (not via Tauri).
HOST=127.0.0.1
PORT=7799

# ── Frontend bundle (Vite) ───────────────────────────────────────────────────

# Host and port the Cubicles backend listens on. Baked into the bundle.
VITE_CUBICLES_HOST=127.0.0.1
VITE_CUBICLES_PORT=7799

# Dev-only absolute paths. Referenced only inside import.meta.env.DEV branches
# so they are tree-shaken out of production builds automatically.
VITE_CUBICLES_ROOT=/path/to/cubicles-ts
VITE_JUICE_ROOT=/path/to/juice
